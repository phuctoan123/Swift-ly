# ============================================================
# URL Shortener — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG bao giờ commit file .env vào Git!
# ============================================================

# --- Application ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
BASE_URL=http://localhost:8000

# --- Database (PostgreSQL / TimescaleDB) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@db:5432/urlshortener
# Cho local dev không dùng Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/urlshortener

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# Cho local dev không dùng Docker:
# REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Sinh bằng: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
DOMAIN_BLACKLIST=malware.com,spam.net,phishing.org

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Short Code ---
SHORT_CODE_LENGTH=7
SHORT_CODE_MAX_RETRIES=5
