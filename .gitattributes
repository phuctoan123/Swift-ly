# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly declare Python, YAML, config files as LF
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.json text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.ico binary
*.db binary
